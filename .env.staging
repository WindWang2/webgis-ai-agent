# ============================================================
# WebGIS AI Agent - 灰度/测试环境配置
# ============================================================

# ======== 环境配置 ========
ENV=staging

# 调试模式 (灰度环境请设为 false)
DEBUG=false

# ======== 数据库配置 ========
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webgis

# ======== Redis 配置 ========
REDIS_HOST=localhost
REDIS_PORT=6379

# ======== 服务端口配置 ========
API_PORT=8000

# ======== 其他配置 ========
DATA_DIR=./data
TMP_DIR=./tmp
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# 禁用数据库默认密码警告
DISABLE_DB_PWD_WARN=true