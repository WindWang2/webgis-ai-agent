# ============================================================
# WebGIS AI Agent 生产环境配置（实际使用）
# ============================================================
# ⚠️ 此文件包含敏感信息，切勿提交到版本控制！
# 已添加到 .gitignore
#
# 
# ======== 环境模式 ========
ENV=production
DEBUG=false
PROJECT_NAME=WebGIS-AI-Agent-PROD
# 
# ======== JWT/认证密钥 ========
JWT_SECRET_KEY=[SET_YOUR_SECURE_RANDOM_STRING_HERE]
# 
# ======== 数据库配置 ========
DATABASE_URL=[SET_YOUR_DATABASE_URL_HERE]
# 
# ======== Redis 配置 ========
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# 
# ======== GitHub 配置 ========
GITHUB_WEBHOOK_SECRET=[SET_HERE]
GITHUB_TOKEN=[SET_HERE]
GITHUB_REPO_OWNER=kevin-zhang-cn
GITHUB_REPO_NAME=webgis-ai-agent
# 
# ======== 飞书通知配置 ========
FEISHU_WEBHOOK_URL=
# 
# ======== 服务端口配置 ========
API_PORT=8000
# 
# ======== CORS 配置 ========
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# 
# ======== 大模型 API 配置 ========
# LLM 提供商: openai / anthropic / azure / local
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=MiniMax-M2.5
LLM_CONTEXT_WINDOW=196608
LLM_MAX_TOKENS=16384

# ======== 日志级别 ========
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ======== 超时配置 ========
PR_TIMEOUT_HOURS=24
PR_MIN_COVERAGE_PERCENT=80