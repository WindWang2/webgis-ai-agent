# ============================================================
# WebGIS AI Agent 生产环境配置
# ============================================================
#
# ⚠️ 安全警告：
# 此文件仅为模板。请将 .env.prod 复制为实际配置
# 确保敏感信息不上传到代码库！
#

# ======== 环境模式 ========
ENV=production
DEBUG=false

# ======== 项目配置 ========
PROJECT_NAME=WebGIS-AI-Agent-PROD

# ======== JWT/认证密钥（必须修改！）=======
JWT_SECRET_KEY=CHANGE_ME_TO_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS

# ======== 数据库配置 ========
# 方式1: 完整 DATABASE_URL（推荐）
DATABASE_URL=postgresql://webgis_user:YOUR_STRONG_PASSWORD@db-prod-host:5432/webgis_prod

# 方式2: 分解的配置（如果不用 DATABASE_URL）
# DB_HOST=your-db-host.example.com
# DB_PORT=5432
# DB_USER=webgis_user
# DB_PASSWORD=YOUR_STRONG_PASSWORD
# DB_NAME=webgis_prod

# ======== Redis 配置 ========
REDIS_URL=redis://redis-prod-host:6379/0
CELERY_BROKER_URL=redis://redis-prod-host:6379/0
CELERY_RESULT_BACKEND=redis://redis-prod-host:6379/1

# ======== 大模型 API 密钥（如使用）=======
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ======== GitHub 配置（Webhook/PR审查）=======
GITHUB_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=webgis-ai-agent

# ======== 飞书通知配置 ========
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR-WEBHOOK-ID
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ======== 服务端口配置 ========
API_PORT=8000

# ======== CORS 配置（生产环境必须指定具体域名）=======
CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]

# ======== 日志级别 ========
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1