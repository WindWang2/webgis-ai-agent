# WebGIS AI Agent 环境变量配置
# 复制此文件为 .env 并修改相应值

# 项目名称
PROJECT_NAME=WebGIS AI Agent

# 调试模式
DEBUG=true

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webgis_ai

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 数据目录
DATA_DIR=./data
TMP_DIR=./tmp

# CORS 允许的来源 (逗号分隔)
CORS_ORIGINS=["*"]
