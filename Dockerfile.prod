# ============================================================
# WebGIS AI Agent 生产环境 Dockerfile
# 多阶段构建，使用 Next.js standalone 输出
# ============================================================

# Stage 1: Frontend Dependencies
FROM node:20-alpine AS frontend-deps
WORKDIR /app/frontend

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci --prefer-offline

# Stage 2: Frontend Builder
FROM node:20-alpine AS frontend-builder
WORKDIR /app/frontend
COPY --from=frontend-deps /app/frontend/node_modules ./node_modules
COPY frontend/ ./

ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_RUNTIME=nodejs
RUN npm run build

# Stage 3: Backend Python Dependencies
FROM python:3.11-slim-bookworm AS backend-deps
WORKDIR /app/backend

COPY requirements.txt .
RUN pip install --no-cache-dir --break-system-packages \
    uv==0.5.11 \
    && uv pip install --system --no-cache -r requirements.txt

# Stage 4: Final Runner
FROM python:3.11-slim-bookworm AS runner
WORKDIR /app/backend

# Install Node.js for frontend standalone server
RUN apt-get update && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Copy frontend standalone output
COPY --from=frontend-builder /app/frontend/.next/standalone ./frontend/.next/standalone
COPY --from=frontend-builder /app/frontend/.next/static ./frontend/.next/static
COPY --from=frontend-builder /app/frontend/public ./frontend/public

# Copy Python packages
COPY --from=backend-deps /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=backend-deps /usr/local/bin /usr/local/bin

# Copy application code
COPY . .

# Create non root user
RUN groupadd --system --gid 1001 appgroup && \
    useradd --system --uid 1001 --gid appgroup --shell /bin/false --home /app appuser && \
    mkdir -p /app/uploads && chown -R appuser:appgroup /app

USER appuser

EXPOSE 3000 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8000/api/v1/health/live || exit 1

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port 8000 & node frontend/.next/standalone/server.js -p 3000"]
