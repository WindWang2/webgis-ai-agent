# ============================================================
# WebGIS AI Agent 环境变量配置
# ============================================================
# 请复制此文件为 .env 并修改相应值
#
# ⚠️ 安全警告：默认密码 'postgres' 仅用于开发/测试！
# 生产环境请务必设置强密码。
#

# ======== 项目配置 ========
# 项目名称
PROJECT_NAME=WebGIS AI Agent
# 调试模式 (生产环境请改为 false)
DEBUG=true

# ======== 数据库配置（两套方式） ========
# ─────────────────────────────────────────────────────
# 方式1: 完整 DATABASE_URL（推荐，最优先）
# 格式: postgresql://user:password@host:port/database_name
# 示例: postgresql://myuser:mypassword123@mydb.example.com:5432/webgis
# ─────────────────────────────────────────────────────
DATABASE_URL=

# ─────────────────────────────────────────────────────
# 方式2: 分解的数据库组件环境变量
# 当 DATABASE_URL 为空时使用，可组合这些变量
# ─────────────────────────────────────────────────────
# 数据库主机
DB_HOST=localhost
# 数据库端口
DB_PORT=5432
# 数据库用户名
DB_USER=postgres
# ⚠️ 数据库密码 - 生产环境请设置为强密码!
DB_PASSWORD=postgres
# 数据库名称
DB_NAME=webgis

# ======== Redis 配置 ========
# Redis 主机（Docker 默认: redis）
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379

# ======== 服务端口配置 ========
# API 服务端口
API_PORT=8000

# ======== 其他配置 ========
# 数据目录
DATA_DIR=./data
# 临时文件目录
TMP_DIR=./tmp

# CORS 允许的来源 (逗号分隔)
CORS_ORIGINS=["*"]

# 禁用数据库默认密码警告（仅用于正式部署测试后）
# DISABLE_DB_PASSWORD_WARN=false